{
  "programs": [
    {
      "id": "mcgill_531",
      "name": "Протокол Макгилла (5-3-1)",
      "description": "Убывающая пирамида: удержание — 10 сек, микропауза — 3 сек, отдых между подходами — 30 сек. Смена стороны — 5 сек.",
      "estimatedTime": "15 минут",
      "exercisesDetails": {
        "Кошка-Верблюд": {
          "goal": "Снижение гидравлического сопротивления и вязкости спинномозговой жидкости, подготовка связочного аппарата.",
          "start": "Квадропедальная позиция. Ладони строго под плечевыми суставами, колени — под тазобедренными.",
          "move": "Плавное сгибание (вверх) и разгибание (вниз) позвоночника. Строго 70-80% амплитуды (крайние точки запрещены)."
        },
        "Скручивания Макгилла": {
          "goal": "Активация прямой мышцы живота без сгибания поясничного отдела.",
          "start": "Лежа на спине. Одна нога выпрямлена, вторая согнута. Кисти под поясницей для контроля нейтрального лордоза.",
          "move": "Отрыв головы, шеи и грудного отдела на 1-2 см от пола как единого жесткого блока. Шея зафиксирована."
        },
        "Боковая Планка": {
          "goal": "Изометрическая активация квадратной мышцы поясницы и косых мышц живота.",
          "start": "На боку, опора на предплечье и латеральную часть стопы (или колени). Исключить ротацию таза.",
          "move": "Подъем таза до формирования прямой векторальной линии от головы до стоп/колен."
        },
        "Охотничья собака": {
          "goal": "Активация разгибателей спины и многораздельных мышц.",
          "start": "Квадропедальная позиция. Спина жестко зафиксирована в нейтральном положении.",
          "move": "Одновременное вытяжение противоположной руки и ноги назад, не выше уровня ягодицы. Стопа натянута на себя."
        },
        "Переход": {
          "goal": "Оптимизация реоксигенации тканей.",
          "start": "-",
          "move": "Смена позиции без потери контроля нейтрального положения позвоночника."
        },
        "Финиш": {
          "goal": "Протокол успешно завершен.",
          "start": "-",
          "move": "Нейромышечный контроль активирован. Осевая компрессия минимизирована."
        }
      },
